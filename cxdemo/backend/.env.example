# CX Intelligence Platform — Environment Variables
# Copy this to .env and fill in your values

# Anthropic API Key (required) — get from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/cxintelligence

# Speech-to-text provider: openai | sarvam | local
WHISPER_PROVIDER=openai

# OpenAI API key (for Whisper audio transcription)
OPENAI_API_KEY=your_openai_key_here

# Sarvam AI key (for Indian language transcription — optional)
SARVAM_API_KEY=your_sarvam_key_here

# Your Vercel frontend URL (for CORS) — e.g. https://your-app.vercel.app
FRONTEND_URL=

# Flask
FLASK_ENV=development
FLASK_DEBUG=true
